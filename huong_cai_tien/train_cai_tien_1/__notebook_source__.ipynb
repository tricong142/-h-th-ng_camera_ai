import torch
import os
from PIL import Image
from cv2 import imread
import sys

sys.path.insert(0, '/kaggle/input/datasets/trcng23/nhan-dien-bien-so-xe/ocr_dataset_/vn_alpr_ocr_from_scratch')

from src.inference.predictor import Predictor

device = 'cuda' if torch.cuda.is_available() else 'cpu'
predictor = Predictor.from_checkpoint(
    '/kaggle/working/runs/exp_kaggle/best.pt',
    device=device,
    decoder='greedy'
)

print("Model loaded successfully!")
print(f"Device: {device}")
print(f"Vocab size: {predictor.vocab.num_classes}")


import cv2

# Test trên một ảnh từ validation set
val_dir = '/kaggle/input/datasets/trcng23/nhan-dien-bien-so-xe/ocr_dataset_/content/ocr_dataset/val'
test_images = os.listdir(val_dir)[:3]  # Lấy 3 ảnh đầu

for img_name in test_images:
    img_path = os.path.join(val_dir, img_name)
    pred_text = predictor.predict_image(img_path)
    print(f"Image: {img_name} → Predicted: {pred_text}")


import cv2

# Load batch ảnh
val_dir = '/kaggle/input/datasets/trcng23/nhan-dien-bien-so-xe/ocr_dataset_/content/ocr_dataset/val'
img_names = os.listdir(val_dir)[:10]

images = []
for img_name in img_names:
    img = cv2.imread(os.path.join(val_dir, img_name), cv2.IMREAD_COLOR)
    images.append(img)

# Predict batch
predictions = predictor.predict_batch(images)

for img_name, pred in zip(img_names, predictions):
    print(f"{img_name} → {pred}")


